<div class="auth-page">
  <div class="auth-form">
    <h2 class="auth-form__title">新規登録</h2>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), id: "new_user", class: "new_user", local: true do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :nickname, "ニックネーム" %>
        <%= f.text_field :nickname, autofocus: true, placeholder: "表示名を入力" %>
      </div>

      <div class="field">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, placeholder: "example@email.com" %>
      </div>

      <div class="field">
        <%= f.label :password, "パスワード" %>
        <% if @validatable %>
          <em>（<%= @minimum_password_length %>文字以上）</em>
        <% end %>
        <%= f.password_field :password, autocomplete: "off", placeholder: "パスワードを入力" %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "パスワード（確認）" %>
        <%= f.password_field :password_confirmation, autocomplete: "off", placeholder: "もう一度入力" %>
      </div>

      <div class="actions">
        <%= f.submit "アカウントを作成" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= link_to "すでにアカウントをお持ちですか？ログイン", new_user_session_path %>
    </div>
  </div>
</div>
