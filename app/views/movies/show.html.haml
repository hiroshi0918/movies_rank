.show-backdrop{ style: "background-image: url('#{@movie.image_url}')" }
  .show-backdrop__image{ style: "background-image: url('#{@movie.image_url}')" }
  .show-backdrop__gradient

.show-content
  .show-poster
    = image_tag @movie.image_url, class: "show-poster__image", alt: @movie.title
    - if user_signed_in? && current_user == @movie.user
      .show-poster__actions
        = link_to "編集", edit_movie_path(@movie.id), class: "btn-edit"
        = link_to "削除", movie_path(@movie.id), class: "btn-delete", data: { turbo_method: :delete, turbo_confirm: "この投稿を削除しますか？" }
    .show-poster__like
      - if user_signed_in?
        - if current_user.already_liked?(@movie)
          = link_to movie_like_path(@movie), class: "like-btn", data: { turbo_method: :delete } do
            %i.fas.fa-thumbs-up
            いいね！ #{@movie.likes_total}
        - else
          = link_to movie_like_path(@movie), class: "like-btn", data: { turbo_method: :post } do
            %i.fas.fa-thumbs-up
            いいね！ #{@movie.likes_total}
      - else
        .like-btn
          %i.fas.fa-thumbs-up
          いいね！ #{@movie.likes_total}

  .show-details
    %h1.show-details__title= @movie.title
    .show-details__meta
      %span.show-details__match 98% マッチ
      %span.show-details__tag= @movie.category
      %span.show-details__label
        監督:
        %strong= @movie.director
    - if @movie.detail.present?
      .show-details__section
        %h3.show-details__section-title あらすじ
        %p.show-details__text= @movie.detail
    - if @movie.youtube_url.present?
      .show-details__video
        %iframe{ width: "100%", height: "400", src: "https://www.youtube.com/embed/#{@movie.youtube_url}", frameborder: "0", allow: "accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture", allowfullscreen: true, title: "movie trailer" }

.comments-section
  .comment-form
    - if user_signed_in?
      = render "layouts/error_messages", model: @comment
      = form_with(model: [@movie, @comment], local: true, id: "new-comment") do |form|
        = form.text_area :text, placeholder: "コメントを入力...", rows: "3", class: "comment-form__input"
        = form.submit "投稿する", class: "comment-form__submit"
    - else
      %p.comment-form__notice
        コメントの投稿には
        = link_to "ログイン", new_user_session_path, style: "color: var(--nf-red); font-weight: 600;"
        が必要です
  .comments-list
    %h3.comments-list__title レビュー一覧
    - if @comments
      - @comments.each do |comment|
        .comment-item
          .comment-item__user= comment.user.nickname
          .comment-item__text= comment.text
