.content2
  .left-content
    = image_tag "#{@movie.image}", class: "left-content__image"
    - if user_signed_in? && current_user == @movie.user
      .left-content--btns
        = link_to "編集", edit_movie_path(@movie.id), class: "edit-btn"
        = link_to "削除", movie_path(@movie.id), class: "destroy-btn", data: { turbo_method: :delete, turbo_confirm: "この投稿を削除しますか？" }
    .left-content--likes
      - if user_signed_in?
        - if current_user.already_liked?(@movie)
          = link_to movie_like_path(@movie), class: "left-content-likes--btn", data: { turbo_method: :delete } do
            %i.fas.fa-thumbs-up いいね！
            = @movie.likes_total
        - else
          = link_to movie_like_path(@movie), class: "left-content-likes--btn", data: { turbo_method: :post } do
            %i.fas.fa-thumbs-up いいね！
            = @movie.likes_total
      - else
        .left-content-likes--btn
          %i.fas.fa-thumbs-up いいね！
          = @movie.likes_total
  .right-content
    .right-content__title
      = @movie.title
    .right-content__middle
      .right-content__middle__info
        監督:
      .right-content__middle__director
        = @movie.director
      .right-content__middle__info
        ジャンル:
      .right-content__middle__category
        = @movie.category
    .right-content__detail
      .right-content__detail__info
        あらすじ
      .right-content__detail__input
        = @movie.detail
    - if @movie.youtube_url.present?
      .right-content__video
        %iframe(width="400" height="280" src="https://www.youtube.com/embed/#{@movie.youtube_url}" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen title="movie trailer")
.chat-space
  .chat-form
    - if user_signed_in?
      = render "layouts/error_messages", model: @comment
      = form_with(model: [@movie, @comment], local: true, id: "new-comment") do |form|
        = form.text_area :text, placeholder: "コメントする", rows: "2", class: "chat-form--box"
        = form.submit "投稿", class: "chat-form--btn"
    - else
      %strong
      %p ※※※ コメントの投稿には新規登録/ログインが必要です ※※※
  .comments
    %p＜レビュー一覧＞
    - if @comments
      - @comments.each do |comment|
        .comments__para
          .comments__para__talker
            = comment.user.nickname
          .comments__para__text
            = comment.text
            %br
