.grid-page
  %h2.grid-page__title 検索結果
  - if @movies.present?
    .grid-container
      - @movies.each do |movie|
        = link_to movie_path(movie), class: "grid-card" do
          = image_tag movie.image_url, class: "grid-card__image", alt: movie.title
          .grid-card__overlay
            .grid-card__title= movie.title
            .grid-card__meta
              %span.likes
                %i.fa.fa-heart
                = movie.likes_total
              %span.category= movie.category
  - else
    %p.grid-page__empty 検索結果が見つかりませんでした
