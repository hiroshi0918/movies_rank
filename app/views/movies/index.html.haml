- if @hero_movie
  .hero-banner
    .hero-banner__backdrop{ style: "background-image: url('#{@hero_movie.image_url}')" }
    .hero-banner__gradient
    .hero-banner__content
      %h1.hero-banner__title= @hero_movie.title
      .hero-banner__meta
        %span.hero-banner__match 98% マッチ
        %span.hero-banner__category= @hero_movie.category
        %span.hero-banner__director= @hero_movie.director
      - if @hero_movie.detail.present?
        %p.hero-banner__description= truncate(@hero_movie.detail, length: 200)
      .hero-banner__buttons
        = link_to movie_path(@hero_movie), class: "hero-btn hero-btn--play" do
          %i.fa.fa-play
          詳細を見る
        - if user_signed_in?
          = link_to movie_like_path(@hero_movie), class: "hero-btn hero-btn--list", data: { turbo_method: (current_user.already_liked?(@hero_movie) ? :delete : :post) } do
            %i.fa.fa-plus
            マイリスト

.home-container
  .rows-container
    - if @all_ranks.present?
      = render partial: "movie_row", locals: { title: "今日のTOP10（日本）", movies: @all_ranks, is_rank: true }

    - if @trending_movies.present?
      = render partial: "movie_row", locals: { title: "視聴中コンテンツ", movies: @trending_movies }

    - if @action_movies.present?
      = render partial: "movie_row", locals: { title: "アクション映画", movies: @action_movies }

    - if @animation_movies.present?
      = render partial: "movie_row", locals: { title: "アニメーション", movies: @animation_movies }

    - if @drama_movies.present?
      = render partial: "movie_row", locals: { title: "ドラマ", movies: @drama_movies }
