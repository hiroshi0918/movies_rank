<div class="catalog-page">
  <section class="catalog-page__intro catalog-page__intro--compact">
    <p class="catalog-page__eyebrow">検索</p>
    <h1 class="catalog-page__title">検索結果</h1>
    <% if params[:keyword].present? %>
      <p class="catalog-page__description">「<%= params[:keyword] %>」に一致する映画です。</p>
    <% else %>
      <p class="catalog-page__description">映画タイトルで気になる作品を探せます。</p>
    <% end %>
  </section>

  <% if @movies.present? %>
    <div class="movie-grid">
      <%= render partial: "movie_card", collection: @movies, as: :movie %>
    </div>
    <div class="catalog-page__pagination">
      <%= paginate @movies %>
    </div>
  <% else %>
    <p class="catalog-page__empty">検索結果が見つかりませんでした</p>
  <% end %>
</div>
