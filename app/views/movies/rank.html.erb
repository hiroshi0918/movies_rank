<div class="grid-page">
  <h2 class="grid-page__title">TOP 10 ランキング</h2>
  <div class="grid-container">
    <% @all_ranks.each_with_index do |movie, i| %>
      <div class="rank-grid-item">
        <div class="rank-badge"><%= i + 1 %></div>
        <%= link_to movie_path(movie), class: "grid-card" do %>
          <%= image_tag movie.image_url, class: "grid-card__image", alt: movie.title %>
          <div class="grid-card__overlay">
            <div class="grid-card__title"><%= movie.title %></div>
            <div class="grid-card__meta">
              <span class="likes">
                <i class="fa fa-heart"></i>
                <%= movie.likes_total %>
              </span>
              <span class="category"><%= movie.category %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
