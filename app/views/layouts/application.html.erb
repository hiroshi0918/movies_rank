<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <title>MoviesRank</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap">
    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
    <%= turbo_include_tags %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body>
    <div class="header">
      <div class="header__left">
        <%= link_to "MoviesRank", root_path, class: "title" %>
        <div class="nav-links">
          <%= link_to "ホーム", root_path, class: "nav-link" %>
          <%= link_to "シリーズ", "#", class: "nav-link" %>
          <%= link_to "映画", "#", class: "nav-link" %>
          <%= link_to "新着&人気", "#", class: "nav-link" %>
          <%= link_to "マイリスト", "#", class: "nav-link" %>
        </div>
      </div>
      <div class="header__right">
        <div class="search-container">
          <%= form_with(url: search_movies_path, local: true, method: :get, class: "search-form") do |form| %>
            <%= form.text_field :keyword, placeholder: "映画を検索する", class: "sbox" %>
            <button class="sbtn" type="submit">
              <i class="fa fa-search"></i>
            </button>
          <% end %>
        </div>
        <% if user_signed_in? %>
          <%= link_to current_user.nickname, user_path(current_user), class: "header__right--btn" %>
          <%= link_to "新規投稿", new_movie_path, class: "header__right--btn" %>
          <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "header__right--btn" %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, class: "header__right--btn" %>
          <%= link_to "新規登録", new_user_registration_path, class: "header__right--btn" %>
        <% end %>
      </div>
    </div>
    <div class="main-content">
      <div class="notifications">
        <% flash.each do |key, value| %>
          <%= content_tag :div, value, class: key %>
        <% end %>
      </div>
      <%= yield %>
    </div>
  </body>
</html>
