<div class="catalog-page">
  <section class="catalog-page__intro">
    <p class="catalog-page__eyebrow">MoviesRank</p>
    <h1 class="catalog-page__title">新着の映画</h1>
    <p class="catalog-page__description">
      投稿された映画を新しい順に一覧で確認できます。気になる作品は詳細ページで予告編やレビューまでまとめて見られます。
    </p>
  </section>

  <% if @movies.present? %>
    <div class="movie-grid">
      <%= render partial: "movie_card", collection: @movies, as: :movie %>
    </div>
    <div class="catalog-page__pagination">
      <%= paginate @movies %>
    </div>
  <% else %>
    <p class="catalog-page__empty">まだ映画が投稿されていません</p>
  <% end %>
</div>
