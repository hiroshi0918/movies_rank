<div class="detail-page">
  <div class="detail-layout">
    <div class="detail-poster">
      <%= movie_poster_tag(@movie, class_name: "detail-poster__image", alt: @movie.title) %>

      <% if user_signed_in? && current_user == @movie.user %>
        <div class="detail-poster__actions">
          <%= link_to "編集", edit_movie_path(@movie.id), class: "detail-button detail-button--secondary" %>
          <%= link_to "削除", movie_path(@movie.id), class: "detail-button detail-button--danger", data: { turbo_method: :delete, turbo_confirm: "この投稿を削除しますか？" } %>
        </div>
      <% end %>

      <div class="detail-poster__like">
        <% if user_signed_in? %>
          <% if current_user.already_liked?(@movie) %>
            <%= link_to movie_like_path(@movie), class: "detail-button detail-button--like", data: { turbo_method: :delete } do %>
              <span>いいねを解除</span>
              <span><%= movie_likes_text(@movie) %></span>
            <% end %>
          <% else %>
            <%= link_to movie_like_path(@movie), class: "detail-button detail-button--like", data: { turbo_method: :post } do %>
              <span>いいねする</span>
              <span><%= movie_likes_text(@movie) %></span>
            <% end %>
          <% end %>
        <% else %>
          <div class="detail-button detail-button--static">
            <span>いいね数</span>
            <span><%= movie_likes_text(@movie) %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="detail-body">
      <p class="detail-body__eyebrow">作品詳細</p>
      <h1 class="detail-body__title"><%= @movie.title %></h1>
      <% if movie_original_title_text(@movie).present? %>
        <p class="detail-body__original-title">原題: <%= movie_original_title_text(@movie) %></p>
      <% end %>
      <div class="detail-body__meta">
        <span class="detail-body__tag"><%= @movie.category %></span>
        <span class="detail-body__meta-item">監督 <strong><%= @movie.director %></strong></span>
        <span class="detail-body__meta-item"><%= movie_likes_text(@movie) %></span>
      </div>

      <% if @movie.detail.present? %>
        <section class="detail-section">
          <h2 class="detail-section__title">あらすじ</h2>
          <div class="detail-section__text"><%= simple_format(@movie.detail) %></div>
        </section>
      <% end %>

      <% if @movie.youtube_url.present? %>
        <section class="detail-section detail-section--trailer">
          <div class="detail-video-card">
            <div class="detail-section__header detail-video-card__header">
              <h2 class="detail-section__title">予告編</h2>
              <%= link_to "YouTubeで開く", "https://www.youtube.com/watch?v=#{@movie.youtube_url}", target: "_blank", rel: "noopener", class: "detail-section__link" %>
            </div>
            <div class="detail-video-card__body">
              <div class="detail-video">
                <iframe src="https://www.youtube.com/embed/<%= @movie.youtube_url %>" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen title="予告編"></iframe>
              </div>
            </div>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</div>

<div class="comments-section" data-controller="comment">
  <div class="comment-form">
    <% if user_signed_in? %>
      <%= render "layouts/error_messages", model: @comment %>
      <%= form_with(model: [@movie, @comment], local: true, id: "new-comment", data: { comment_target: "form", action: "submit->comment#submit" }) do |form| %>
        <%= form.text_area :text, placeholder: "コメントを入力...", rows: "3", class: "comment-form__input", data: { comment_target: "input" } %>
        <%= form.submit "投稿する", class: "comment-form__submit", data: { comment_target: "submit" } %>
      <% end %>
    <% else %>
      <p class="comment-form__notice">
        コメントの投稿には
        <%= link_to "ログイン", new_user_session_path, class: "comment-form__link" %>
        が必要です
      </p>
    <% end %>
  </div>
  <div class="comments-list" data-comment-target="list">
    <h3 class="comments-list__title">レビュー一覧</h3>
    <% if @comments.present? %>
      <% @comments.each do |comment| %>
        <div class="comment-item">
          <div class="comment-item__user"><%= comment.user.nickname %></div>
          <div class="comment-item__text"><%= comment.text %></div>
        </div>
      <% end %>
    <% else %>
      <p class="comments-list__empty">まだレビューはありません</p>
    <% end %>
  </div>
</div>
