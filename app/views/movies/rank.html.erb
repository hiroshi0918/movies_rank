<div class="catalog-page">
  <section class="catalog-page__intro catalog-page__intro--compact">
    <p class="catalog-page__eyebrow">ランキング</p>
    <h1 class="catalog-page__title">人気ランキング</h1>
    <p class="catalog-page__description">いいね数が多い映画を上位10件まで表示しています。</p>
  </section>

  <% if @all_ranks.present? %>
    <div class="movie-grid movie-grid--ranked">
      <% @all_ranks.each_with_index do |movie, index| %>
        <%= render partial: "movie_card", locals: { movie: movie, rank: index + 1 } %>
      <% end %>
    </div>
  <% else %>
    <p class="catalog-page__empty">ランキング対象の映画はまだありません</p>
  <% end %>
</div>
